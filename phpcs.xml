<?xml version="1.0"?>
<ruleset name="Propel">
    <description>
        Propel Coding Standard.

        Extends Spryker Coding Standard.
    </description>

    <config name="installed_paths" value="../../spryker/code-sniffer"/>

    <arg value="nps"/>

    <file>src/</file>

    <rule ref="Spryker">
        <exclude ref="Spryker.Commenting.FileDocBlock.FileDocBlockWrong" />
    </rule>
</ruleset>
